# SocialFlow environment variables
# Copy to .env and fill in real values. Never commit .env.
#
# 安全要求：
#   - 所有密码 / 密钥都必须替换为强随机值，禁止使用 "***REDACTED-DB-PASSWORD***" 这类弱密码
#   - 生产环境凭证应通过 Nacos / Vault 等配置中心动态注入，本地仅用于开发
#   - .env 文件已被 .gitignore，但请在本机也设置 chmod 600 防止泄露

# ---- Database ----
# 推荐生成方式: openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ---- 腾讯云 COS 对象存储 ----
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key

# ---- pgvector ----
PG_PASSWORD=CHANGE_ME_STRONG_PG_PASSWORD

# ---- Security: AES-256-GCM key for user API key storage (32 bytes hex = 64 chars) ----
# 必须替换！生成方式：openssl rand -hex 32
# 警告：此密钥用于加密用户存储的 LLM API Key，泄露后所有用户密钥都将解密
AI_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# ---- Jasypt (application.yml placeholder encryption) ----
JASYPT_ENCRYPTOR_PASSWORD=CHANGE_ME_STRONG_JASYPT_PASSWORD

# ---- WeChat Official Account ----
WECHAT_MP_SECRET=your_wechat_mp_secret_here

# ---- Optional: system-wide default LLM keys (only if you want a fallback) ----
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENAI_API_KEY=

# ====================================================================
# ---- 部署脚本（deploy.py / verify.py 等）使用的环境变量 ----
# ====================================================================
# 这些不需要写进 .env，建议放到 ~/.socialflow.env 之类的本机文件，运行前 source。
# SOCIALFLOW_SSH_HOST=<生产机 IP 或域名>
# SOCIALFLOW_SSH_USER=root
# SOCIALFLOW_SSH_PASSWORD=<SSH 密码；建议改用密钥登录后留空>
# SOCIALFLOW_REMOTE_DIR=/opt/socialflow
# SOCIALFLOW_MYSQL_USER=root
# SOCIALFLOW_MYSQL_PASSWORD=<生产 MySQL 密码>
# SOCIALFLOW_MYSQL_DB=socialflow
